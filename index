<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Test AV Directionnel - Acuité Visuelle</title>
    <style>
        body { margin: 0; background: #000; overflow: hidden; font-family: sans-serif; color: white; }
        video {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; opacity: 0.2; z-index: 1; transform: scaleX(-1);
        }
        #letterDisplay {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 100px; font-weight: bold; color: white;
            opacity: 0; z-index: 10; pointer-events: none;
            text-shadow: 0 0 10px black;
            max-width: 90vw;
            text-align: center;
        }
        #ui {
            position: absolute; top: 10px; left: 10px; z-index: 20;
            background: rgba(0,0,0,0.8); padding: 10px; border-radius: 8px;
            max-width: 300px;
        }
        .stat { font-size: 12px; margin: 2px 0; color: #0f0; font-family: monospace; }
        .error { color: #f55; }
        .speed-gauge {
            height: 6px; background: #333; margin-top: 5px; border-radius: 3px; overflow: hidden;
        }
        .speed-bar {
            height: 100%; width: 0%; background: linear-gradient(90deg, #0f0, #ff0, #f00);
            transition: width 0.1s linear;
        }
        button {
            background: #4ecdc4; border: none; padding: 10px; border-radius: 5px;
            cursor: pointer; font-weight: bold; width: 100%; margin-top: 5px;
        }
        button.secondary { background: #555; color: white; }
        #startOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 100; display: flex; flex-direction: column;
            align-items: center; justify-content: center; text-align: center; padding: 20px;
        }
        #calibPanel {
            display: none; margin-top: 10px; padding-top: 10px;
            border-top: 1px solid #444; text-align: center;
        }
        .calib-bar-container {
            height: 20px; border: 1px dashed #666; margin: 10px auto;
            display: flex; justify-content: center; align-items: center; width: 12mm;
        }
        .calib-bar { height: 100%; background: red; width: 10mm; transform-origin: center; }
        #letterSizeControl {
            position: absolute; top: 10px; right: 10px; z-index: 20;
            background: rgba(0,0,0,0.8); padding: 10px; border-radius: 8px;
            width: 120px;
            text-align: center;
        }
        #letterSizeLabel {
            font-size: 11px; margin-bottom: 5px;
        }
        #letterSizeValue {
            font-size: 16px; font-weight: bold; margin: 5px 0;
        }
        .size-control-buttons {
            display: flex; justify-content: space-between; margin-top: 5px;
        }
        .size-btn {
            width: 30px; height: 30px; font-size: 16px; font-weight: bold;
            background: #555; border: none; border-radius: 5px; cursor: pointer;
        }
        #keyboard {
            position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%);
            display: flex; flex-wrap: wrap; justify-content: center; gap: 5px;
            z-index: 25; background: rgba(0,0,0,0.7); padding: 10px; border-radius: 10px;
            max-width: 90vw;
        }
        .key {
            width: 40px; height: 40px; font-size: 20px; font-weight: bold;
            background: #333; border: none; border-radius: 5px; cursor: pointer;
            color: white; transition: all 0.2s;
        }
        .key:hover {
            background: #555;
            transform: scale(1.1);
        }
        .key.validated {
            background: #28a745;
        }
        .key.invalid {
            background: #dc3545;
        }
        #startMessage {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 48px; font-weight: bold; color: #4ecdc4;
            opacity: 0; z-index: 20;
            text-shadow: 0 0 10px #4ecdc4;
            transition: opacity 0.3s;
        }
        #scoreTopPanel {
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 25;
            background: rgba(0,0,0,0.8);
            padding: 8px 15px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 14px;
            text-align: center;
            white-space: nowrap;
        }
        #leftControls {
            position: fixed;
            bottom: 20px;
            left: 20px;
            z-index: 30;
        }
        #rightControls {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 30;
        }
        .control-btn {
            width: 100px;
            padding: 8px;
            font-size: 12px;
            font-weight: bold;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin-bottom: 5px;
        }
        .calib-btn {
            background: #555 !important;
            color: white !important;
        }
        .finish-btn {
            background: #ffc107 !important;
            color: #000 !important;
        }
        .finish-btn:hover {
            background: #ffd54f !important;
        }
        #finalStatsOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); z-index: 200; display: none;
            flex-direction: column; align-items: center; justify-content: center;
            padding: 20px; text-align: center;
        }
        .final-stat-box {
            background: rgba(0,0,0,0.8); padding: 20px; border-radius: 10px;
            margin: 10px; width: 90%; max-width: 400px;
        }
        .final-stat-title {
            font-size: 18px; margin-bottom: 15px; color: #4ecdc4;
        }
        .final-stat-item {
            font-size: 16px; margin: 8px 0; color: white;
        }
        .final-stat-value {
            font-weight: bold; color: #28a745;
        }
        #restartButton {
            background: #28a745; margin-top: 20px;
        }
    </style>
</head>
<body>
    <div id="startOverlay">
        <h1>Test Acuité Directionnel</h1>
        <p>Trouvez la taille minimale de lettre que vous pouvez identifier<br>pour chaque direction de mouvement.</p>
        <button onclick="startApp()">DÉMARRER</button>
        <p id="errorMsg" class="error"></p>
    </div>
    <video id="video" playsinline autoplay muted></video>
    <div id="letterDisplay">A</div>
    <div id="startMessage">Début</div>

    <div id="ui" style="display:none;">
        <div class="stat" id="statusInit">Test en cours...</div>
        <div class="stat" id="statusSpeed">Vitesse: 0</div>
        <div class="speed-gauge"><div class="speed-bar" id="speedBar"></div></div>
        <div id="scoreTopPanel">Direction: -- | Taille: -- px</div>
        <div class="stat" id="statusDist" style="margin-top:5px;">Distance: -- cm</div>
        <div class="stat" id="statusSize">Taille: -- px</div>

        <hr style="border-color:#333; margin: 5px 0;">

        <div id="calibPanel">
            <p style="font-size:11px; margin:0; color:#ddd;">Ajustez la barre rouge à <b>1 cm</b> avec une règle.</p>
            <div class="calib-bar-container">
                <div class="calib-bar" id="calibBar"></div>
            </div>
            <input type="range" id="calibSlider" min="0.5" max="2.0" step="0.05" value="1.0" oninput="updateCalib()" style="width:100%;">
            <button onclick="saveCalib()" style="background:#28a745; margin-top:5px;">Sauvegarder</button>
        </div>
    </div>

    <div id="letterSizeControl" style="display:none;">
        <div id="letterSizeLabel">Taille lettre (px)</div>
        <div id="letterSizeValue">100</div>
        <div class="size-control-buttons">
            <button class="size-btn secondary" onclick="adjustLetterSize(-5)">-</button>
            <input type="number" id="letterSizeInput" min="5" max="300" value="100" onchange="updateLetterSizeFromInput()">
            <button class="size-btn secondary" onclick="adjustLetterSize(5)">+</button>
        </div>
    </div>

    <div id="keyboard" style="display:none;">
        <!-- Clavier généré par JavaScript -->
    </div>

    <div id="leftControls" style="display:none;">
        <button class="control-btn calib-btn" onclick="toggleCalib()">📏 Calibrer</button>
    </div>
    <div id="rightControls" style="display:none;">
        <button class="control-btn finish-btn" onclick="showFinalResults()">FIN</button>
    </div>

    <div id="finalStatsOverlay">
        <div class="final-stat-box">
            <div class="final-stat-title">Résultats par direction</div>
            <div class="final-stat-item">👉 Droite : <span class="final-stat-value" id="globalMinRight">-- px</span></div>
            <div class="final-stat-item">👈 Gauche : <span class="final-stat-value" id="globalMinLeft">-- px</span></div>
            <div class="final-stat-item">⬆️ Haut : <span class="final-stat-value" id="globalMinUp">-- px</span></div>
            <div class="final-stat-item">⬇️ Bas : <span class="final-stat-value" id="globalMinDown">-- px</span></div>
        </div>
        <button id="restartButton" onclick="restartTest()">Recommencer</button>
    </div>

    <script>
        // --- CONSTANTES ---
        const TEST_STATES = {
            RIGHT: 'TESTING_RIGHT',
            LEFT: 'TESTING_LEFT',
            UP: 'TESTING_UP',
            DOWN: 'TESTING_DOWN',
            IDLE: 'IDLE'
        };

        // --- ÉLÉMENTS DOM ---
        const video = document.getElementById('video');
        const letterEl = document.getElementById('letterDisplay');
        const ui = document.getElementById('ui');
        const letterSizeControl = document.getElementById('letterSizeControl');
        const keyboard = document.getElementById('keyboard');
        const leftControls = document.getElementById('leftControls');
        const rightControls = document.getElementById('rightControls');
        const startOverlay = document.getElementById('startOverlay');
        const finalStatsOverlay = document.getElementById('finalStatsOverlay');
        const letterSizeInputEl = document.getElementById('letterSizeInput');
        const letterSizeValueEl = document.getElementById('letterSizeValue');
        const scoreTopPanel = document.getElementById('scoreTopPanel');

        // --- ÉTATS ---
        let state = 'IDLE';
        let currentTestState = TEST_STATES.IDLE;
        let currentDisplayedLetter = '';
        let flashTimeout = null;
        let lastFlashTime = 0;
        let calibrationFactor = 1.0;

        // --- MODÈLE DE DÉTECTION DE VISAGE ---
        let model;

        // --- PARAMÈTRES ---
        let distance = 60;
        let rawDistance = 60;
        let speed = 0;
        let smoothedSpeed = 0;
        let lastHeadPos = null;
        let lastTime = performance.now();
        let lastMovementDirection = null;
        let letterSizePx = 100;

        // --- RÉSULTATS PAR DIRECTION ---
        let directionResults = {
            right: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
            left: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
            up: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
            down: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 }
        };

        // --- LETTRES DISPONIBLES ---
        const letters = "D F P V A N L C O E R U S Z H".split(" ");

        // --- INITIALISATION DU CLAVIER ---
        function initKeyboard() {
            keyboard.innerHTML = '';
            const lettersSorted = [...letters].sort();

            lettersSorted.forEach(letter => {
                const key = document.createElement('button');
                key.className = 'key';
                key.textContent = letter;
                key.onclick = () => validateLetter(letter);
                keyboard.appendChild(key);
            });
        }

        // --- INITIALISATION ---
        async function startApp() {
            loadCalib();
            initKeyboard();

            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } }
                });
                video.srcObject = stream;
                video.onloadedmetadata = async () => {
                    startOverlay.style.display = 'none';
                    ui.style.display = 'block';
                    letterSizeControl.style.display = 'block';
                    keyboard.style.display = 'flex';
                    leftControls.style.display = 'block';
                    rightControls.style.display = 'block';
                    video.play();

                    document.getElementById('statusInit').innerText = "Chargement IA...";
                    model = await blazeface.load();
                    document.getElementById('statusInit').innerText = "Test en cours...";

                    startDirectionTest(TEST_STATES.RIGHT);
                    loop();
                };
            } catch (err) {
                document.getElementById('errorMsg').innerText = "Erreur Caméra : " + err.message;
            }
        }

        // --- DÉMARRER UN TEST POUR UNE DIRECTION ---
        function startDirectionTest(directionState) {
            currentTestState = directionState;
            state = 'IDLE';

            const directionName = directionState.replace('TESTING_', '').toLowerCase();
            letterSizePx = directionResults[directionName].currentSize;
            updateLetterDisplay();

            document.getElementById('statusInit').innerText =
                `Test ${directionName.toUpperCase()} (Taille: ${letterSizePx}px)`;

            // Mettre à jour le panneau de score
            const directionNames = {
                right: "👉 Droite",
                left: "👈 Gauche",
                up: "⬆️ Haut",
                down: "⬇️ Bas"
            };
            scoreTopPanel.innerHTML = `${directionNames[directionName]} | Taille: ${letterSizePx} px`;
        }

        // --- MACHINE D'ÉTAT MODIFIÉE ---
        function handleState(currentSpeed, now) {
            const minSpeedTrigger = 150;
            const flashDuration = 60;
            const cooldownDuration = 1000;

            if (state === 'IDLE') {
                if (currentTestState !== TEST_STATES.IDLE &&
                    currentSpeed > minSpeedTrigger &&
                    (now - lastFlashTime > cooldownDuration)) {

                    const detectedDirection = lastMovementDirection;

                    if ((currentTestState === TEST_STATES.RIGHT && detectedDirection === 'right') ||
                        (currentTestState === TEST_STATES.LEFT && detectedDirection === 'left') ||
                        (currentTestState === TEST_STATES.UP && detectedDirection === 'up') ||
                        (currentTestState === TEST_STATES.DOWN && detectedDirection === 'down')) {

                        state = 'WAITING_VALIDATION';
                        lastFlashTime = now;
                        currentDisplayedLetter = letters[Math.floor(Math.random() * letters.length)];
                        letterEl.innerText = currentDisplayedLetter;
                        letterEl.style.opacity = '1';

                        flashTimeout = setTimeout(() => {
                            if (state === 'WAITING_VALIDATION') {
                                letterEl.style.opacity = '0';
                                if (currentTestState !== TEST_STATES.IDLE) {
                                    handleLetterFailure();
                                }
                            }
                        }, flashDuration);
                    }
                }
            }
        }

        // --- GESTION DE L'ÉCHEC DE VALIDATION ---
        function handleLetterFailure() {
            if (currentTestState === TEST_STATES.IDLE) return;

            const currentDirection = currentTestState.replace('TESTING_', '').toLowerCase();
            const result = directionResults[currentDirection];

            result.failureCount++;

            // Augmenter la taille pour le prochain essai
            letterSizePx = Math.min(300, letterSizePx + 5);
            result.currentSize = letterSizePx;

            updateLetterDisplay();
            state = 'IDLE';

            // Passer à l'essai suivant
            startNextDirectionTest();
        }

        // --- PASSAGE À L'ESSAI SUIVANT ---
        function startNextDirectionTest() {
            const maxAttempts = 10;
            const currentDirection = currentTestState.replace('TESTING_', '').toLowerCase();
            if (directionResults[currentDirection].failureCount >= maxAttempts) {
                switch(currentTestState) {
                    case TEST_STATES.RIGHT: startDirectionTest(TEST_STATES.LEFT); break;
                    case TEST_STATES.LEFT: startDirectionTest(TEST_STATES.UP); break;
                    case TEST_STATES.UP: startDirectionTest(TEST_STATES.DOWN); break;
                    case TEST_STATES.DOWN: showFinalResults(); return;
                }
                return;
            }

            startDirectionTest(currentTestState);
        }

        // --- VALIDATION D'UNE LETTRE (MODIFIÉ) ---
        function validateLetter(letter) {
            if (state !== 'WAITING_VALIDATION') return;

            clearTimeout(flashTimeout);
            flashTimeout = null;

            const keys = document.querySelectorAll('.key');
            keys.forEach(k => k.classList.remove('validated', 'invalid'));

            const clickedKey = Array.from(keys).find(k => k.textContent === letter);

            if (clickedKey && currentTestState !== TEST_STATES.IDLE) {
                const currentDirection = currentTestState.replace('TESTING_', '').toLowerCase();
                const result = directionResults[currentDirection];

                clickedKey.classList.add('validated');
                letterEl.style.opacity = '0';

                // Mettre à jour la taille minimale réussie
                if (letterSizePx < result.minSize) {
                    result.minSize = letterSizePx;
                }
                result.successCount++;

                // Diminuer la taille pour le prochain essai
                letterSizePx = Math.max(5, letterSizePx - 5);
                result.currentSize = letterSizePx;

                updateLetterDisplay();
                state = 'IDLE';

                startNextDirectionTest();
            }
        }

        // --- AFFICHAGE DES RÉSULTATS FINAUX ---
        function showFinalResults() {
            // Masquer les éléments de test
            ui.style.display = 'none';
            letterSizeControl.style.display = 'none';
            keyboard.style.display = 'none';
            leftControls.style.display = 'none';
            rightControls.style.display = 'none';

            // Afficher les résultats
            finalStatsOverlay.style.display = 'flex';

            // Mettre à jour les résultats
            document.getElementById('globalMinRight').textContent =
                directionResults.right.minSize !== Infinity ? `${directionResults.right.minSize} px` : "Non testé";
            document.getElementById('globalMinLeft').textContent =
                directionResults.left.minSize !== Infinity ? `${directionResults.left.minSize} px` : "Non testé";
            document.getElementById('globalMinUp').textContent =
                directionResults.up.minSize !== Infinity ? `${directionResults.up.minSize} px` : "Non testé";
            document.getElementById('globalMinDown').textContent =
                directionResults.down.minSize !== Infinity ? `${directionResults.down.minSize} px` : "Non testé";
        }

        // --- RECOMMENCER LE TEST ---
        function restartTest() {
            currentTestState = TEST_STATES.IDLE;
            state = 'IDLE';
            letterSizePx = 100;

            directionResults = {
                right: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
                left: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
                up: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 },
                down: { minSize: Infinity, currentSize: 100, successCount: 0, failureCount: 0 }
            };

            finalStatsOverlay.style.display = 'none';
            ui.style.display = 'block';
            letterSizeControl.style.display = 'block';
            keyboard.style.display = 'flex';
            leftControls.style.display = 'block';
            rightControls.style.display = 'block';

            startDirectionTest(TEST_STATES.RIGHT);
        }

        // --- BOUCLE PRINCIPALE ---
        async function loop() {
            if (!model) return;

            const predictions = await model.estimateFaces(video, false);

            if (predictions.length > 0) {
                const face = predictions[0];
                const nose = face.landmarks[2];
                const leftEye = face.landmarks[0];
                const rightEye = face.landmarks[1];

                // 1. DISTANCE
                const distInterYeuxPx = Math.sqrt(
                    Math.pow(rightEye[0] - leftEye[0], 2) +
                    Math.pow(rightEye[1] - leftEye[1], 2)
                );
                const K_FACTOR = 2800;
                if (distInterYeuxPx > 5) {
                    let calculatedDist = K_FACTOR / distInterYeuxPx;
                    rawDistance = calculatedDist;
                    distance = (distance * 0.9) + (rawDistance * 0.1);
                    distance = Math.max(30, Math.min(120, distance));
                }

                // 2. VITESSE
                const now = performance.now();
                if (lastHeadPos) {
                    const dt = (now - lastTime);
                    if (dt > 16) {
                        const dx = nose[0] - lastHeadPos.x;
                        const dy = nose[1] - lastHeadPos.y;
                        const distPx = Math.sqrt(dx*dx + dy*dy);
                        let rawSpeed = distPx / dt;
                        smoothedSpeed = (smoothedSpeed * 0.7) + (rawSpeed * 0.3);
                        speed = smoothedSpeed * 1000;
                    }
                }
                lastHeadPos = { x: nose[0], y: nose[1] };
                lastTime = now;

                // 3. DÉTECTION DE LA DIRECTION
                detectDirection(nose, lastHeadPos);

                handleState(speed, now);
                updateStats();

            } else {
                smoothedSpeed = smoothedSpeed * 0.9;
                speed = smoothedSpeed * 1000;
                updateStats();
            }
            requestAnimationFrame(loop);
        }

        // --- DÉTECTION DE DIRECTION ---
        function detectDirection(currentPos, lastPos) {
            if (!lastPos) return;

            const dx = currentPos.x - lastPos.x;
            const dy = currentPos.y - lastPos.y;
            const threshold = 10;

            if (Math.abs(dx) > threshold || Math.abs(dy) > threshold) {
                if (Math.abs(dx) > Math.abs(dy)) {
                    lastMovementDirection = dx > 0 ? 'right' : 'left';
                } else {
                    lastMovementDirection = dy > 0 ? 'down' : 'up';
                }
            }
        }

        // --- METTRE À JOUR LES STATISTIQUES ---
        function updateStats() {
            document.getElementById('statusSpeed').innerText = `Vitesse: ${Math.round(speed)}`;
            document.getElementById('statusDist').innerText = `Dist: ~${Math.round(distance)} cm`;
            document.getElementById('statusSize').innerText = `Taille: ${letterSizePx} px`;

            let pct = Math.min(100, (speed / 250) * 100);
            document.getElementById('speedBar').style.width = `${pct}%`;
            const bar = document.getElementById('speedBar');
            if(speed > 150) bar.style.background = '#f00';
            else bar.style.background = 'linear-gradient(90deg, #0f0, #ff0, #f00)';
        }

        // --- GESTION DE LA TAILLE DES LETTRES ---
        function updateLetterSizeFromInput() {
            const newSize = parseInt(letterSizeInputEl.value);
            if (!isNaN(newSize) && newSize >= 5 && newSize <= 300) {
                letterSizePx = newSize;
                updateLetterDisplay();
            }
            letterSizeInputEl.value = letterSizePx;
        }

        function adjustLetterSize(delta) {
            letterSizePx = Math.max(5, Math.min(300, letterSizePx + delta));
            letterSizeInputEl.value = letterSizePx;
            updateLetterDisplay();
        }

        function updateLetterDisplay() {
            letterSizeValueEl.innerText = letterSizePx;
            letterEl.style.fontSize = letterSizePx + 'px';
        }

        // --- CALIBRATION ---
        function toggleCalib() {
            const panel = document.getElementById('calibPanel');
            panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
        }
        function updateCalib() {
            calibrationFactor = parseFloat(document.getElementById('calibSlider').value);
            document.getElementById('calibBar').style.transform = `scaleX(${calibrationFactor})`;
        }
        function saveCalib() {
            localStorage.setItem('avd_blazeface_calib_v3', calibrationFactor);
            document.getElementById('calibPanel').style.display = 'none';
            updateStats();
        }
        function loadCalib() {
            const saved = localStorage.getItem('avd_blazeface_calib_v3');
            if (saved) {
                calibrationFactor = parseFloat(saved);
                document.getElementById('calibSlider').value = calibrationFactor;
                updateCalib();
            }
        }
    </script>
    <!-- Inclure le modèle Blazeface depuis un CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@3.9.0"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/blazeface@0.0.6"></script>
</body>
</html>
